{
  "name": "mobile-angular-capacitor-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build:mobile": "ng build",
    "production": "ng build --configuration production",
    "test": "jest",
    "lint": "ng lint",
    "lintfix": "ng lint --fix",
    "audit": "npm audit",
    "format": "prettier --write \"src/**/*.ts\"",
    "mobile:android": "npm run build:mobile && npx cap copy android && npx cap open android",
    "mobile:ios": "npm run build:mobile && npx cap copy ios && npx cap open ios",
    "outdated": "npm outdated --depth=0",
    "upgrade": "ncu --upgrade"
  },
  "dependencies": {
    "@angular/common": "^20.0.1",
    "@angular/compiler": "^20.0.1",
    "@angular/core": "^20.0.1",
    "@angular/forms": "^20.0.1",
    "@angular/platform-browser": "^20.0.1",
    "@angular/platform-browser-dynamic": "^20.0.1",
    "@angular/router": "^20.0.1",
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.1",
    "@angular/cli": "^20.0.1",
    "@angular/compiler-cli": "^20.0.1",
    "@capacitor/cli": "^7.2.0",
    "@testing-library/angular": "^17.3.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/jest": "^29.5.14",
    "angular-eslint": "^19.7.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.0",
    "npm-check-updates": "^18.0.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
